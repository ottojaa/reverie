    <color name="brand_turquoise">#4FD1C5</color>
    <!-- Launcher icon + splash: dark charcoal ground, so the turquoise "R" reads as the logo. -->
    <color name="ic_launcher_background">#121212</color>
    <!-- Branded splash is always dark (turquoise R on charcoal), matching the launcher icon + login mark. -->
    <color name="splash_background">#121212</color>
    <!-- Launch window bg follows the app theme (dark override in values-night) to avoid a flash. -->
    <color name="window_background">#F8F7F4</color>
</resources>
